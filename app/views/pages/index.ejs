<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Lista de Tarefas</title>
</head>

<body>

    <h1>Lista de Tarefas</h1>

    <button onclick="window.location='/nova-tarefa'">Nova tarefa</button>

    <br><br>

    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Prazo</th>
                <th>Situação</th>
                <th>Ações</th>
            </tr>
        </thead>

        <tbody>

            <% if (Array.isArray(listaTarefas) && listaTarefas.length > 0) { 
                let situacao = ["Cancelada","Pendente","Iniciada","Finalizada","Em Atraso"];

                listaTarefas.forEach((item) => { %>

                    <tr>
                        <td><%= item.id_tarefa %></td>

                        <td><%= item.nome_tarefa %></td>

                        <td><%= moment(item.prazo_tarefa).format('L') %></td>

                        <td><%= situacao[item.situacao_tarefa] %></td>

                        <td>
                            <a href="/editar?id=<%= item.id_tarefa %>">Editar</a>

                            |

                            <a href="/teste-delete-logico?id=<%= item.id_tarefa %>" 
                               onclick="return confirm('Deseja excluir esta tarefa?')">
                               Excluir
                            </a>
                        </td>
                    </tr>

            <%  }); 
            } else { %>

                <tr>
                    <td colspan="5">Sem tarefas para exibir</td>
                </tr>

            <% } %>

        </tbody>
    </table>

</body>

</html>

